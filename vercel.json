{
  "version": 2,
  "buildCommand": "npm run build",
  "functions": {
    "server.js": {
      "includeFiles": "frontend/dist/**"
    }
  },
  "routes": [
    {
      "src": "/(api|webhook|health)(.*)",
      "dest": "/server.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/frontend/dist/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ]
}
